# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# pdf.js worker (copied on prepare/postinstall)
/public/pdf.worker.min.mjs

# next.js
/.next/
/out/

# production
/build

# Capacitor native projects (generated via `npx cap add`)
/android
/ios
/.capacitor

# drizzle-kit local artifacts (commit generated SQL migrations under /drizzle when you use migrate)
# Keep schema in src/db; ignore accidental kit caches only:
.drizzle

# misc
.DS_Store
*.pem
*.log
*.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets; keep the template
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / OS
.idea/
.vscode/*
!.vscode/extensions.json
Thumbs.db

.worktrees/
