# Copy to `.env.local` for local development (never commit secrets).

# --- Database (Neon Postgres recommended) ---
# Use the pooled connection string from Neon Console → Connection details.
# Example: ...@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public site URL (local or Vercel production URL)
AUTH_URL=http://localhost:3000
# Legacy alias still recognized by Auth.js
# NEXTAUTH_URL=http://localhost:3000

# --- Client gates / API ---
# AuthScreen + sync gate. Leave unset/false for local-first without login.
# Set true only when DATABASE_URL + AUTH_SECRET are configured.
# NEXT_PUBLIC_AUTH_ENABLED=true

# Absolute API origin when the client is not same-origin (Capacitor mobile).
# Leave empty for same-origin web (localhost / Vercel).
# NEXT_PUBLIC_API_BASE_URL=https://your-app.vercel.app

# Optional store / APK links for the “Descargá la app” banner (mobile web only)
# NEXT_PUBLIC_ANDROID_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=...
# NEXT_PUBLIC_IOS_DOWNLOAD_URL=https://apps.apple.com/app/id...

# --- Password reset email (optional; no npm email packages) ---
# Without these, forgot-password still creates a token and logs the reset URL
# to the server console. In non-production (or with AUTH_DEV_RESET_URL=1) the
# API also returns `resetUrl` in the JSON response for local testing.
# AUTH_DEV_RESET_URL=1
# RESEND_API_KEY=
# RESEND_FROM=OpenBalance <onboarding@resend.dev>
# SMTP_URL=  # reserved for later (Nodemailer/SMTP); not wired yet
